# Database connection (get this from Neon dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Node environment
NODE_ENV=production

# Port (Glitch will set this automatically)
PORT=3000

# Base path for Vite
BASE_PATH=/
